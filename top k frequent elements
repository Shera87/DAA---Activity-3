class Solution(object):
    def topKFrequent(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: List[int]
        """
        # Step 1: Count frequencies
        count = {}
        for n in nums:
            count[n] = 1 + count.get(n, 0)
            
        # Step 2: Create buckets where index is frequency
        # Length is len(nums) + 1 because a number could appear up to n times
        freq_buckets = [[] for _ in range(len(nums) + 1)]
        
        for num, f in count.items():
            freq_buckets[f].append(num)
            
        # Step 3: Collect the top k frequent elements
        res = []
        for i in range(len(freq_buckets) - 1, 0, -1):
            for n in freq_buckets[i]:
                res.append(n)
                if len(res) == k:
                    return res
